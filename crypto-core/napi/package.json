{
  "name": "@2fapi/crypto-native",
  "version": "0.1.0",
  "description": "Native Ristretto255 cryptographic operations for 2FApi (via napi-rs)",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "crypto-native",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-musl"
      ]
    }
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "napi build --release --platform",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ]
}
